<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<BorderPane xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.optimatch.view.StudentController"
            styleClass="content-pane">

    <!-- Left Side: Student List -->
    <left>
        <VBox styleClass="list-panel" spacing="10" prefWidth="350">
            <padding>
                <Insets top="15" right="15" bottom="15" left="15"/>
            </padding>

            <!-- Search Box -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <TextField fx:id="searchField" promptText="Search students..." HBox.hgrow="ALWAYS"/>
                <Button text="Clear" onAction="#clearSearch" styleClass="secondary-button"/>
            </HBox>

            <!-- Student Table -->
            <TableView fx:id="studentTable" VBox.vgrow="ALWAYS" styleClass="data-table">
                <columns>
                    <TableColumn fx:id="colStudentId" text="ID" prefWidth="80"/>
                    <TableColumn fx:id="colName" text="Name" prefWidth="150"/>
                    <TableColumn fx:id="colGpa" text="GPA" prefWidth="60"/>
                    <TableColumn fx:id="colPartner" text="Partner" prefWidth="50"/>
                </columns>
                <placeholder>
                    <Label text="No students found"/>
                </placeholder>
            </TableView>

            <!-- List Actions -->
            <HBox spacing="10" alignment="CENTER">
                <Button text="New Student" onAction="#newStudent" styleClass="primary-button"/>
                <Button text="Refresh" onAction="#refresh" styleClass="secondary-button"/>
            </HBox>

            <!-- Student Count -->
            <Label fx:id="countLabel" text="0 students" styleClass="count-label"/>
        </VBox>
    </left>

    <!-- Center: Student Form -->
    <center>
        <ScrollPane fitToWidth="true" styleClass="form-scroll">
            <VBox styleClass="form-panel" spacing="15">
                <padding>
                    <Insets top="20" right="25" bottom="20" left="25"/>
                </padding>

                <!-- Form Title -->
                <HBox alignment="CENTER_LEFT" spacing="10">
                    <Label fx:id="formTitle" text="New Student" styleClass="form-title"/>
                    <Region HBox.hgrow="ALWAYS"/>
                    <Button fx:id="deleteButton" text="Delete" onAction="#deleteStudent"
                            styleClass="danger-button" visible="false"/>
                </HBox>

                <Separator/>

                <!-- Basic Information Section -->
                <Label text="Basic Information" styleClass="section-title"/>

                <GridPane hgap="15" vgap="12" styleClass="form-grid">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" halignment="RIGHT"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>

                    <!-- Student ID -->
                    <Label text="Student ID:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <TextField fx:id="studentIdField" promptText="e.g., 123456789"
                               GridPane.rowIndex="0" GridPane.columnIndex="1"/>

                    <!-- Name -->
                    <Label text="Full Name:" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <TextField fx:id="nameField" promptText="Enter full name"
                               GridPane.rowIndex="1" GridPane.columnIndex="1"/>

                    <!-- Email -->
                    <Label text="Email:" GridPane.rowIndex="2" GridPane.columnIndex="0"/>
                    <TextField fx:id="emailField" promptText="student@example.com"
                               GridPane.rowIndex="2" GridPane.columnIndex="1"/>

                    <!-- GPA -->
                    <Label text="GPA:" GridPane.rowIndex="3" GridPane.columnIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          GridPane.rowIndex="3" GridPane.columnIndex="1">
                        <Spinner fx:id="gpaSpinner" editable="true" prefWidth="100"/>
                        <Label text="(0.00 - 4.00)" styleClass="hint-label"/>
                    </HBox>
                </GridPane>

                <Separator/>

                <!-- Partner Section -->
                <Label text="Partner (Optional)" styleClass="section-title"/>

                <GridPane hgap="15" vgap="12" styleClass="form-grid">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" halignment="RIGHT"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>

                    <Label text="Partner:" GridPane.rowIndex="0" GridPane.columnIndex="0"/>
                    <HBox spacing="10" alignment="CENTER_LEFT"
                          GridPane.rowIndex="0" GridPane.columnIndex="1">
                        <ComboBox fx:id="partnerCombo" promptText="Select partner (optional)"
                                  HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                        <Button text="Clear" onAction="#clearPartner" styleClass="small-button"/>
                    </HBox>

                    <Label text="" GridPane.rowIndex="1" GridPane.columnIndex="0"/>
                    <Label text="Partners will be assigned to the same project"
                           styleClass="hint-label"
                           GridPane.rowIndex="1" GridPane.columnIndex="1"/>
                </GridPane>

                <Separator/>

                <!-- Preferences Section -->
                <Label text="Project Preferences" styleClass="section-title"/>
                <Label text="Rank projects from most preferred (1st) to least preferred (5th)"
                       styleClass="hint-label"/>

                <GridPane hgap="15" vgap="12" styleClass="form-grid">
                    <columnConstraints>
                        <ColumnConstraints minWidth="120" halignment="RIGHT"/>
                        <ColumnConstraints hgrow="ALWAYS" minWidth="200"/>
                    </columnConstraints>

                    <!-- Preference 1 -->
                    <Label text="1st Choice:" GridPane.rowIndex="0" GridPane.columnIndex="0"
                           styleClass="pref-label-1"/>
                    <ComboBox fx:id="pref1Combo" promptText="Select 1st choice project"
                              GridPane.rowIndex="0" GridPane.columnIndex="1"
                              maxWidth="Infinity"/>

                    <!-- Preference 2 -->
                    <Label text="2nd Choice:" GridPane.rowIndex="1" GridPane.columnIndex="0"
                           styleClass="pref-label-2"/>
                    <ComboBox fx:id="pref2Combo" promptText="Select 2nd choice project"
                              GridPane.rowIndex="1" GridPane.columnIndex="1"
                              maxWidth="Infinity"/>

                    <!-- Preference 3 -->
                    <Label text="3rd Choice:" GridPane.rowIndex="2" GridPane.columnIndex="0"
                           styleClass="pref-label-3"/>
                    <ComboBox fx:id="pref3Combo" promptText="Select 3rd choice project"
                              GridPane.rowIndex="2" GridPane.columnIndex="1"
                              maxWidth="Infinity"/>

                    <!-- Preference 4 -->
                    <Label text="4th Choice:" GridPane.rowIndex="3" GridPane.columnIndex="0"
                           styleClass="pref-label-4"/>
                    <ComboBox fx:id="pref4Combo" promptText="Select 4th choice project"
                              GridPane.rowIndex="3" GridPane.columnIndex="1"
                              maxWidth="Infinity"/>

                    <!-- Preference 5 -->
                    <Label text="5th Choice:" GridPane.rowIndex="4" GridPane.columnIndex="0"
                           styleClass="pref-label-5"/>
                    <ComboBox fx:id="pref5Combo" promptText="Select 5th choice project"
                              GridPane.rowIndex="4" GridPane.columnIndex="1"
                              maxWidth="Infinity"/>
                </GridPane>

                <Region VBox.vgrow="ALWAYS"/>

                <Separator/>

                <!-- Form Actions -->
                <HBox spacing="15" alignment="CENTER_RIGHT">
                    <Button text="Clear Form" onAction="#clearForm" styleClass="secondary-button"/>
                    <Button fx:id="saveButton" text="Save Student" onAction="#saveStudent"
                            styleClass="primary-button" prefWidth="120"/>
                </HBox>

                <!-- Status Message -->
                <Label fx:id="statusLabel" text="" styleClass="status-message"/>

            </VBox>
        </ScrollPane>
    </center>

</BorderPane>
